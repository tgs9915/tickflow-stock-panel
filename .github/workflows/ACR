name: Build and Push to Aliyun ACR

on:
  schedule:
    - cron: '0 2 * * *'      # 每天北京时间上午 10:00 (UTC 2:00) 自动检测并构建最新版本
  workflow_dispatch:        # 支持在 GitHub 网页上手动点击按钮一键构建

env:
  REGISTRY: crpi-tkwi5rp22e1ibriu.cn-qingdao.personal.cr.aliyuncs.com
  # 【重要】请将下方修改为：你的阿里云命名空间/你的阿里云仓库名
  # 例如：tgs9915/tickflow-stock-panel
  IMAGE_NAME: cy233/tickflow-stock-panel
  UPSTREAM_REPO: shy3130/tickflow-stock-panel # 原作者仓库

jobs:
  build-and-push:
    runs-on: ubuntu-latest

    steps:
      # 1. 检出原作者的最新代码
      - name: Checkout Upstream Repository
        uses: actions/checkout@v4
        with:
          repository: ${{ env.UPSTREAM_REPO }}
          ref: main

      # 2. 设置 Docker Buildx 构建器
      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3

      # 3. 登录到 阿里云镜像服务 (登录凭证已配置在 GitHub Secrets 中)
      - name: Log in to Aliyun Registry
        uses: docker/login-action@v3
        with:
          registry: ${{ env.REGISTRY }}
          username: ${{ secrets.ALIYUN_USERNAME }}
          password: ${{ secrets.ALIYUN_PASSWORD }}

      # 4. 提取元数据和标签
      - name: Extract metadata
        id: meta
        uses: docker/metadata-action@v5
        with:
          images: ${{ env.REGISTRY }}/${{ env.IMAGE_NAME }}
          tags: |
            type=raw,value=latest
            type=sha,format=short

      # 5. 编译并推送镜像至阿里云
      - name: Build and push Docker image
        uses: docker/build-push-action@v6
        with:
          context: .
          file: ./Dockerfile
          push: true
          tags: ${{ steps.meta.outputs.tags }}
          labels: ${{ steps.meta.outputs.labels }}
          # 使用 GitHub Actions 缓存加速后续编译
          cache-from: type=gha
          cache-to: type=gha,mode=max
